{
  "functions": {
    "api/auth/login.js":    { "memory": 128, "maxDuration": 5 },
    "api/auth/callback.js": { "memory": 128, "maxDuration": 10 }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "https://anica-blip.github.io/3c-word-search/admin/login.html",
      "permanent": false
    },
    {
      "source": "/admin",
      "destination": "https://anica-blip.github.io/3c-word-search/admin/",
      "permanent": false
    },
    {
      "source": "/admin/login.html",
      "destination": "https://anica-blip.github.io/3c-word-search/admin/login.html",
      "permanent": false
    },
    {
      "source": "/admin/signout.html",
      "destination": "https://anica-blip.github.io/3c-word-search/admin/signout.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}
