{
  "functions": {
    "api/auth/login.js": {
      "memory": 128,
      "maxDuration": 5
    },
    "api/auth/callback.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/auth/login",
      "destination": "/api/auth/login.js"
    },
    {
      "source": "/api/auth/callback",
      "destination": "/api/auth/callback.js"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "https://anica-blip.github.io/3c-word-search/admin/login.html",
      "permanent": false
    },
    {
      "source": "/:path*",
      "destination": "https://anica-blip.github.io/3c-word-search/admin/login.html",
      "permanent": false
    }
  ]
}
