{
  "functions": {
    "api/auth/login.js": {
      "memory": 128,
      "maxDuration": 5,
      "includeFiles": "api/auth/login.js"
    },
    "api/auth/callback.js": {
      "memory": 128,
      "maxDuration": 10,
      "includeFiles": "api/auth/callback.js"
    }
  },
  "routes": [
    {
      "src": "/api/auth/login",
      "dest": "/api/auth/login.js"
    },
    {
      "src": "/api/auth/callback",
      "dest": "/api/auth/callback.js"
    },
    {
      "src": "/(.*)",
      "status": 308,
      "headers": {
        "Location": "https://anica-blip.github.io/3c-word-search/admin/login.html"
      }
    }
  ]
}
