# .vercelignore — 3C Word Search
# Vercel serves OAuth ONLY — all content lives on GitHub Pages

# Static content — not needed on Vercel
public/
admin/
js/
static/

# Static files
*.html
*.css
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.md
*.json

# Non-auth API files
api/puzzles.js

# Keep only OAuth endpoints
!api/
!api/auth/
!api/auth/login.js
!api/auth/callback.js
