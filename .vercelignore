# .vercelignore — 3C Word Search
# Vercel should ONLY deploy /api/auth folder for OAuth
# All other content is hosted on GitHub Pages

# Ignore static content directories (not needed on Vercel)
public/
js/
static/
admin/

# Ignore static files (not needed on Vercel)
*.html
*.css
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.md

# Ignore non-OAuth API files
api/puzzles.js

# Only deploy OAuth endpoints
!api/auth/
!api/auth/login.js
!api/auth/callback.js
